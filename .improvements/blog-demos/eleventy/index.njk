---
layout: base.njk
title: Blog
---
<h1>Blog</h1>
<p>Thoughts on visualization, AI-assisted development, and accessibility.</p>

<ul class="post-list">
{% for post in collections.posts %}
  <li>
    <div class="date">{{ post.date | readableDate }}</div>
    <h3 style="margin: 0.3rem 0;"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
    {% if post.data.description %}<p>{{ post.data.description }}</p>{% endif %}
  </li>
{% endfor %}
</ul>
