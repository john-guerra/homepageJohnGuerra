<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title or "Blog" }} — John Guerra</title>
  {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@400;700&display=swap"
    rel="stylesheet"
  />
  <style>
    body { font-family: "Lato", sans-serif; background: #fefefa; color: #222; }
    h1, h2, h3, h4 { font-family: "Playfair Display", serif; }
    .container-blog { max-width: 720px; margin: 0 auto; padding: 2rem 1rem; }
    a { color: #FF9800; }
    img { max-width: 100%; height: auto; border-radius: 6px; margin: 1rem 0; }
    .post-meta { color: #888; font-size: 0.9em; margin-bottom: 2rem; }
    .post-list { list-style: none; padding: 0; }
    .post-list li { margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid #eee; }
    .post-list .date { color: #888; font-size: 0.85em; }
    .nav-top { border-bottom: 1px solid #eee; padding: 1rem; }
  </style>
</head>
<body>
  <nav class="nav-top">
    <div class="container-blog" style="padding: 0;">
      <a href="/" style="font-weight: 700; text-decoration: none; color: #222;">John Guerra · Blog</a>
    </div>
  </nav>
  <main class="container-blog">
    {{ content | safe }}
  </main>
</body>
</html>
