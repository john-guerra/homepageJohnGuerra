---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (d) =>
  new Date(d).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---
<BaseLayout title="Blog">
  <h1>Blog</h1>
  <p>Thoughts on visualization, AI-assisted development, and accessibility.</p>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <div class="date">{formatDate(post.data.date)}</div>
        <h3 style="margin: 0.3rem 0;">
          <a href={`${import.meta.env.BASE_URL}/${post.slug}/`.replace(/\/+/g, "/")}>{post.data.title}</a>
        </h3>
        {post.data.description && <p>{post.data.description}</p>}
      </li>
    ))}
  </ul>
</BaseLayout>
