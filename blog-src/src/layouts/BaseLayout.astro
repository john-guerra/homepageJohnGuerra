---
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — John Guerra</title>
  {description && <meta name="description" content={description} />}
  <link rel="icon" type="image/x-icon" href="/favicon.png" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@400;700&family=Roboto+Condensed:wght@700&display=swap"
    rel="stylesheet"
  />
  <style is:global>
    body {
      font-family: "Lato", sans-serif;
      background: #fefefa;
      color: #222;
    }
    h1, h2, h3, h4 { font-family: "Playfair Display", serif; }
    .container-blog { max-width: 720px; margin: 0 auto; padding: 2rem 1rem; }
    a { color: #FF9800; }
    a:hover { color: #e68a00; }
    img { max-width: 100%; height: auto; border-radius: 6px; margin: 1rem 0; }
    code {
      background: #f5f5f0;
      padding: 0.1em 0.3em;
      border-radius: 3px;
      font-size: 0.9em;
      color: #222;
    }
    pre code { background: transparent; padding: 0; }
    pre {
      background: #f5f5f0;
      padding: 1rem;
      border-radius: 6px;
      overflow-x: auto;
    }
    blockquote {
      border-left: 3px solid #FF9800;
      padding-left: 1rem;
      color: #555;
      margin: 1rem 0;
    }
    .post-meta { color: #888; font-size: 0.9em; margin-bottom: 2rem; }
    .post-list { list-style: none; padding: 0; }
    .post-list li {
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #eee;
    }
    .post-list .date { color: #888; font-size: 0.85em; }
    .nav-top {
      border-bottom: 1px solid #eee;
      padding: 0.75rem 1rem;
      background: #fff;
    }
    .nav-top-inner {
      max-width: 720px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .nav-brand {
      font-family: "Playfair Display", serif;
      font-weight: 700;
      text-decoration: none;
      color: #222;
      font-size: 1.1rem;
    }
    .nav-brand:hover { color: #222; text-decoration: none; }
    .nav-back { font-size: 0.9rem; color: #888; text-decoration: none; }
    .nav-back:hover { color: #FF9800; }
  </style>
</head>
<body>
  <nav class="nav-top">
    <div class="nav-top-inner">
      <a href="/blog/" class="nav-brand">John Guerra · Blog</a>
      <a href="/" class="nav-back">← back to johnguerra.co</a>
    </div>
  </nav>
  <main class="container-blog">
    <slot />
  </main>
</body>
</html>
